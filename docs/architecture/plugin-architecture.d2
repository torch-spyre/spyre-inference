direction: down

bookends: "Model Bookends" {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"
  direction: right

  EMB: "SpyreVocabParallelEmbedding\n(Spyre lookup;\nTP shard mask on CPU)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  LM: "SpyreParallelLMHead\nfloat16 → logits\nvocab partition padded to 64×32" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
}

granite: "Granite-3 8B Decoder Layer (× 32)" {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"

  N1: "SpyreRMSNorm" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  QKV: "SpyreQKVParallelLinear\n(D2H after F.linear)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  ROPE: "SpyreRotaryEmbedding\n(CPU fallback)" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  ATTN: "SpyreAttentionImpl\n(mixed CPU+Spyre)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  O_PROJ: "SpyreRowParallelLinear\n(H2D before F.linear,\nall_reduce when TP>1)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  N2: "SpyreRMSNorm" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  GATE: "MergedColumnParallelLinear" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  ACT: "SpyreSiluAndMul" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  DOWN: "SpyreRowParallelLinear\n(all_reduce when TP>1)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }

  N1 -> QKV -> ROPE -> ATTN -> O_PROJ
  O_PROJ -> N2: "+residual"
  N2 -> GATE -> ACT -> DOWN
}

attn_detail: "SpyreAttentionImpl Pipeline (default backend)" {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"

  S1: "Bring q/k/v to CPU\n(Spyre slicing corrupts views)" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  S2: "Reshape & cache new K/V\n(per-token overwrite into\nlist-of-pages on Spyre)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  S3: "Per-sequence loop\n(varlen via query_start_loc;\npad query_len to 32)" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  S4: "Online softmax over pages\nQ @ Kᵀ → +mask → softmax → @V\n(compiled per (num_blocks, q_len))" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  S5: "Per-token write-back\n(spyre.overwrite into output)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }

  S1 -> S2 -> S3 -> S4 -> S5
}

bookends.EMB -> granite: "hidden states"
granite -> bookends.LM: "final hidden"
granite.ATTN -> attn_detail: "detail" {style.stroke-dash: 3}

legend: " " {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"
  direction: right

  L1: "Spyre device" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  L2: "CPU fallback" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  L3: "Mixed CPU + Spyre" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
}
