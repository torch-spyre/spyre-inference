direction: down

bookends: "Model Bookends" {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"
  direction: right

  EMB: "SpyreVocabParallelEmbedding\n(aten.embedding = CPU fallback;\nweights/output on Spyre)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  LP: "SpyreLogitsProcessor\n(logits.contiguous())" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  LM: "SpyreParallelLMHead\nF.linear on Spyre → logits→CPU\n(TP≥1 vocab shard; pad to 64×32)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
}

granite: "Granite Decoder Layer (× N)" {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"

  N1: "SpyreRMSNorm" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  QKV: "QKVParallelLinear (un-fused)\nq,k,v = 3× F.linear on Spyre" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  ROPE: "SpyreRotaryEmbedding\n(CPU fallback via\nspyre_rotary_cpu op)" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  ATTN: "SpyreAttentionImpl\n(mixed CPU+Spyre)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  O_PROJ: "RowParallelLinear — o_proj\n(upstream; F.linear on Spyre,\nall_reduce when TP>1)" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  N2: "SpyreRMSNorm" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  GATE: "MergedColumnParallelLinear (un-fused)\ngate,up = 2× F.linear on Spyre" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  ACT: "SpyreSiluAndMul\nsilu(gate) * up on Spyre" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  DOWN: "RowParallelLinear — down_proj\n(upstream; all_reduce when TP>1)" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }

  N1 -> QKV -> ROPE -> ATTN -> O_PROJ
  O_PROJ -> N2: "+residual"
  N2 -> GATE -> ACT -> DOWN
}

attn_detail: "SpyreAttentionImpl Pipeline" {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"

  S1: "Bring q/k/v to CPU\n(Spyre slicing corrupts views)" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  S2: "Reshape & cache new K/V\n(per-token overwrite into\nlist-of-pages on Spyre)" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
  S3: "Per-sequence varlen loop\n(query_start_loc; pad q_len to 32)" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  S4: "Online softmax over pages\nQ @ Kᵀ·scale → soft-cap? →\n+mask → softmax → @V\n(compiled per (num_blocks, q_len))" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  S5: "Stage result on CPU,\nthen bulk-copy into\nSpyre output buffer" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }

  S1 -> S2 -> S3 -> S4 -> S5
}

bookends.EMB -> granite: "hidden states"
granite -> bookends.LP: "final hidden"
bookends.LP -> bookends.LM: "lm_head"
granite.ATTN -> attn_detail: "detail" {style.stroke-dash: 3}

legend: " " {
  style.fill: "#e0e0e0"
  style.stroke: "#9e9e9e"
  style.font-color: "#212121"
  direction: right

  L1: "Spyre device" {
    style.fill: "#1565c0"
    style.stroke: "#0d47a1"
    style.font-color: "#ffffff"
  }
  L2: "CPU fallback" {
    style.fill: "#e65100"
    style.stroke: "#bf360c"
    style.font-color: "#ffffff"
  }
  L3: "Mixed CPU + Spyre" {
    style.fill: "#2e7d32"
    style.stroke: "#1b5e20"
    style.font-color: "#ffffff"
  }
}
